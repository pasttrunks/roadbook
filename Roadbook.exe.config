<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <runtime>
    <!--
      Windows can preserve Mark-of-the-Web on DLLs extracted from a downloaded
      ZIP. Roadbook ships and trusts these bundled assemblies, so allow the
      .NET Framework host used by pywebview/pythonnet to load them.
    -->
    <loadFromRemoteSources enabled="true" />
  </runtime>
</configuration>
